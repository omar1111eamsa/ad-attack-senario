# Force Libvirt provider
ENV['VAGRANT_DEFAULT_PROVIDER'] = 'libvirt'

Vagrant.configure("2") do |config|
  # === Global Configuration ===
  config.vm.box_check_update = false
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # === Network Configuration ===
  # Isolated host-only lab network managed by libvirt
  NETWORK = "192.168.121"
  
  # === Box Configuration (Libvirt-compatible) ===
  BOX_SERVER = "peru/windows-server-2019-standard-x64-eval"
  BOX_WIN10 = "peru/windows-10-enterprise-x64-eval"
  BOX_KALI = "kalilinux/rolling"

  # === Helper Method: Windows VM ===
  def windows_vm(config, name, box, ip, memory, cpus=2)
    config.vm.define name do |node|
      node.vm.box = box
      node.vm.hostname = name
      node.vm.communicator = "winrm"
      node.vm.boot_timeout = 1200
      node.winrm.retry_limit = 60
      node.winrm.retry_delay = 10
      
      # Private network with static IP (Libvirt auto-configures)
      node.vm.network "private_network", ip: ip

      node.vm.provider "libvirt" do |v|
        v.memory = memory
        v.cpus = cpus
        
        # Graphics configuration for GUI access
        v.graphics_type = "spice"
        v.video_type = "qxl"
        v.channel :type => 'spicevmc', :target_name => 'com.redhat.spice.0', :target_type => 'virtio'
        
        # Input configuration (fixes mouse cursor sync)
        v.input :type => "tablet", :bus => "usb"
        
        # Storage configuration
        v.disk_bus = "sata"
        v.nic_model_type = "e1000"
        
        # CPU configuration
        v.cpu_mode = "host-passthrough"
      end
    end
  end

  # === VM Definitions ===
  
  # Domain Controller
  windows_vm(config, "dc", BOX_SERVER, "#{NETWORK}.10", 2048, 2)
  
  # Certificate Authority
  windows_vm(config, "ca", BOX_SERVER, "#{NETWORK}.20", 2048, 2)
  
  # Windows 10 Client
  windows_vm(config, "win10", BOX_WIN10, "#{NETWORK}.40", 3072, 2)
  
  # Kali Attacker (with Ansible provisioner)
  config.vm.define "attacker" do |node|
    node.vm.box = BOX_KALI
    node.vm.hostname = "attacker"
    node.vm.network "private_network", ip: "#{NETWORK}.50"
    
    node.vm.provider "libvirt" do |v|
      v.memory = 2048
      v.cpus = 2
      v.graphics_type = "spice"
      v.video_type = "qxl"
      v.cpu_mode = "host-passthrough"
      v.input :type => "tablet", :bus => "usb"
    end

    # === Ansible Provisioner ===
    # Runs after all VMs are up (industry standard pattern)
    node.vm.provision "ansible" do |ansible|
      ansible.limit = "all"
      ansible.playbook = "../ansible/playbooks/site.yml"
      ansible.inventory_path = "../ansible/inventory.yml"
      ansible.config_file = "../ansible/ansible.cfg"
      ansible.verbose = true
    end
  end
end
